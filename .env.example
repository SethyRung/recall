# Local Postgres (Docker)
POSTGRES_USER=recall
POSTGRES_PASSWORD=recall
POSTGRES_DB=recall

# Nuxt Hub database
DATABASE_DRIVER=postgres-js
DATABASE_URL=postgresql://recall:recall@localhost:5432/recall

# MiniMax chat (OpenAI-compatible)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_API_KEY=
MINIMAX_CHAT_MODEL=MiniMax-M3

# OpenAI embeddings
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Retrieval
NUXT_TOP_K=5
NUXT_SIMILARITY_THRESHOLD=0.3

# Chunking
NUXT_CHUNK_SIZE=500
NUXT_CHUNK_OVERLAP=50
