# Local Postgres (Docker)
POSTGRES_USER=recall
POSTGRES_PASSWORD=recall
POSTGRES_DB=recall

# Nuxt Hub database
DATABASE_DRIVER=postgres-js
DATABASE_URL=postgresql://recall:recall@localhost:5432/recall

# Better Auth
NUXT_BETTER_AUTH_BASE_URL=
NUXT_BETTER_AUTH_SECRET=

# LLM provider (OpenAI-compatible)
NUXT_LLM_BASE_URL=https://api.minimaxi.chat/v1
NUXT_LLM_API_KEY=
NUXT_LLM_MODEL=MiniMax-M3

# Embeddings provider
NUXT_EMBED_API_KEY=
NUXT_EMBED_MODEL=text-embedding-3-small

# Retrieval
NUXT_TOP_K=5
NUXT_SIMILARITY_THRESHOLD=0.3

# Chunking
NUXT_CHUNK_SIZE=500
NUXT_CHUNK_OVERLAP=50

# Better Auth (admin only)
NUXT_BETTER_AUTH_SECRET=
NUXT_BETTER_AUTH_URL=http://localhost:3000
NUXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
